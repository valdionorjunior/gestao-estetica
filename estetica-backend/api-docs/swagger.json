al }"},"401":{"description":"Não autenticado"},"403":{"description":"Sem permissão (apenas ADMIN)"}},"security":[{"JWT":[]}],"summary":"Novos pacientes cadastrados por mês","tags":["Relatórios"]}}},"info":{"title":"Estética Natalia Salvador — API","description":"## API REST — Sistema de Gestão Clínica\n\nSistema de gestão completo para a clínica **Estética Natalia Salvador**.\n\n### Autenticação\nTodas as rotas protegidas exigem um **Bearer Token JWT** no header:\n```\nAuthorization: Bearer <access_token>\n```\n\n### Fluxo de autenticação\n1. `POST /auth/register` — Criar conta\n2. `POST /auth/login` — Obter `accessToken` e `refreshToken`\n3. `POST /auth/refresh` — Renovar `accessToken` com o `refreshToken`\n4. `POST /auth/logout` — Invalidar sessão\n\n### Roles disponíveis\n| Role | Acesso |\n|------|--------|\n| `ADMIN` | Acesso total |\n| `MEDICO` | Agenda, prontuário, relatórios |\n| `RECEPCIONISTA` | Agenda, pacientes |\n| `PACIENTE` | Acesso ao próprio histórico |\n\n### Respostas de erro padrão\n| Código | Descrição |\n|--------|-----------|\n| 400 | Dados inválidos ou validação falhou |\n| 401 | Não autenticado (token ausente ou expirado) |\n| 403 | Sem permissão (role insuficiente) |\n| 404 | Recurso não encontrado |\n| 409 | Conflito (ex: e-mail já cadastrado) |\n| 429 | Rate limit excedido |\n| 500 | Erro interno do servidor |","version":"1.0.0","contact":{"name":"Estética Natalia Salvador","url":"","email":"contato@esteticanataliasalvador.com.br"},"license":{"name":"Proprietary","url":""}},"tags":[{"name":"Autenticação","description":"Registro, login, refresh token e logout"},{"name":"Pacientes","description":"Gestão completa de pacientes da clínica"},{"name":"Agenda","description":"Agendamentos, calendário e controle de status"},{"name":"Prontuário","description":"Prontuário eletrônico e fichas de atendimento"},{"name":"Financeiro","description":"Contas a pagar/receber e dashboard financeiro"},{"name":"Estoque","description":"Produtos, movimentações e alertas de estoque"},{"name":"Relatórios","description":"Relatórios gerenciais por período"}],"servers":[{"url":"http://localhost:3000","description":"Desenvolvimento Local"},{"url":"https://api.esteticanataliasalvador.com.br","description":"Produção"}],"components":{"securitySchemes":{"JWT":{"scheme":"bearer","bearerFormat":"JWT","type":"http","description":"Insira o accessToken JWT obtido no login"}},"schemas":{"RegisterDto":{"type":"object","properties":{"email":{"type":"string","example":"admin@clinica.com"},"password":{"type":"string","example":"Senha@123","minLength":8},"nome":{"type":"string","example":"Maria Silva"},"role":{"type":"string","enum":["ADMIN","MEDICO","RECEPCIONISTA","PACIENTE"],"default":"RECEPCIONISTA"},"clinicaId":{"type":"string","description":"UUID da clínica"}},"required":["email","password"]},"LoginDto":{"type":"object","properties":{"email":{"type":"string","example":"admin@clinica.com"},"password":{"type":"string","example":"Senha@123"}},"required":["email","password"]},"RefreshTokenDto":{"type":"object","properties":{"refreshToken":{"type":"string"}},"required":["refreshToken"]},"CreatePacienteDto":{"type":"object","properties":{"nome":{"type":"string","example":"Maria da Silva"},"cpf":{"type":"string","example":"123.456.789-00","description":"CPF (será criptografado)"},"dataNascimento":{"type":"string","example":"1990-05-15"},"telefone":{"type":"string","example":"(11) 99999-9999"},"email":{"type":"string","example":"maria@email.com"},"endereco":{"type":"string"},"cidade":{"type":"string"},"estado":{"type":"string","example":"SP"},"cep":{"type":"string","example":"01310-100"}},"required":["nome"]},"UpdatePacienteDto":{"type":"object","properties":{"nome":{"type":"string","example":"Maria da Silva"},"cpf":{"type":"string","example":"123.456.789-00","description":"CPF (será criptografado)"},"dataNascimento":{"type":"string","example":"1990-05-15"},"telefone":{"type":"string","example":"(11) 99999-9999"},"email":{"type":"string","example":"maria@email.com"},"endereco":{"type":"string"},"cidade":{"type":"string"},"estado":{"type":"string","example":"SP"},"cep":{"type":"string","example":"01310-100"}}},"CreateAgendamentoDto":{"type":"object","properties":{"pacienteId":{"type":"string"},"profissionalId":{"type":"string"},"procedimentoId":{"type":"string"},"dataHoraInicio":{"type":"string","example":"2025-08-10T09:00:00-03:00"},"dataHoraFim":{"type":"string","example":"2025-08-10T10:00:00-03:00"},"observacoes":{"type":"string"},"valor":{"type":"number","description":"Valor em R$"}},"required":["pacienteId","profissionalId","dataHoraInicio","dataHoraFim"]},"UpdateAgendamentoDto":{"type":"object","properties":{"pacienteId":{"type":"string"},"profissionalId":{"type":"string"},"procedimentoId":{"type":"string"},"dataHoraInicio":{"type":"string","example":"2025-08-10T09:00:00-03:00"},"dataHoraFim":{"type":"string","example":"2025-08-10T10:00:00-03:00"},"observacoes":{"type":"string"},"valor":{"type":"number","description":"Valor em R$"}}},"UpdateAgendamentoStatusDto":{"type":"object","properties":{"status":{"type":"string","enum":["AGENDADO","CONFIRMADO","EM_ATENDIMENTO","CONCLUIDO","CANCELADO","FALTA"]},"motivoCancelamento":{"type":"string"}}},"UpdateProntuarioDto":{"type":"object","properties":{"historicoMedico":{"type":"string","description":"Histórico médico (será criptografado)"},"alergias":{"type":"string","description":"Alergias (será criptografado)"},"medicamentosUso":{"type":"string","description":"Medicamentos em uso (será criptografado)"},"observacoes":{"type":"string"}}},"CreateFichaDto":{"type":"object","properties":{"titulo":{"type":"string"},"conteudo":{"type":"string","description":"Conteúdo da ficha (será criptografado)"},"agendamentoId":{"type":"string"}},"required":["titulo"]},"UpdateFichaDto":{"type":"object","properties":{"titulo":{"type":"string"},"conteudo":{"type":"string"},"status":{"type":"string","enum":["ABERTA","FECHADA"]}}},"CreateContaDto":{"type":"object","properties":{"tipo":