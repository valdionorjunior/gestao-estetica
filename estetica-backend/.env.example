# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estetica_ns
DB_USER=estetica_user
DB_PASSWORD=estetica_pass

# JWT
JWT_SECRET=sua-chave-secreta-jwt-aqui-minimo-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua-chave-refresh-secreta-aqui-minimo-32
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=20

# Criptografia AES-256 para campos sensíveis (LGPD)
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=chave-aes-256-bits-aqui-32-chars-obrig

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3001

# ─── LGPD ────────────────────────────────────────────────────────────────────
# Contato do encarregado de dados (DPO — Art. 41 LGPD)
LGPD_DPO_EMAIL=dpo@esteticanataliasalvador.com.br
# Prazo de retenção de logs de auditoria em dias (Art. 37 LGPD)
LGPD_AUDIT_RETENTION_DAYS=365

# ─── MARKETING / COMUNICAÇÃO ──────────────────────────────────────────────────
# Email (SMTP — ex: SendGrid, Resend, Gmail)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=sua-api-key-aqui
SMTP_FROM=noreply@esteticanataliasalvador.com.br

# SMS (Twilio)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=seu-auth-token-twilio
TWILIO_FROM_NUMBER=+5511999999999

# WhatsApp (Evolution API — self-hosted ou cloud)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-evolution
EVOLUTION_INSTANCE=estetica-ns

# ─── INTEGRAÇÕES: RD STATION ──────────────────────────────────────────────────
# Obtenha em: https://developers.rdstation.com/ → OAuth2 → API Key
RD_STATION_API_KEY=

# ─── INTEGRAÇÕES: LEADLOVERS ──────────────────────────────────────────────────
# Obtenha em: https://app.leadlovers.com → Configurações → Integração
LEADLOVERS_API_KEY=
LEADLOVERS_MAQUINA_ID=

# ─── IA NO PRONTUÁRIO (OpenAI) ────────────────────────────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
# Whisper (transcrição): $0.006/minuto | GPT-4o-mini: ~$0.002/1K tokens
OPENAI_API_KEY=

# ─── TELEMEDICINA ─────────────────────────────────────────────────────────────
# Sem config: usa Jitsi Meet (gratuito, sem API key)
# Com Daily.co: salas privadas, tokens de host/participante
# Obtenha em: https://dashboard.daily.co/developers
DAILY_CO_API_KEY=
# Prefixo do nome da sala (padrão: estetica-ns)
TELEMEDICINA_ROOM_PREFIX=estetica-ns
