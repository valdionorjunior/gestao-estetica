# Servidor
PORT=3000
NODE_ENV=development

# Banco de Dados
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estetica_ns
DB_USER=estetica_user
DB_PASSWORD=estetica_pass

# JWT
JWT_SECRET=sua-chave-secreta-jwt-aqui-minimo-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=sua-chave-refresh-secreta-aqui-minimo-32
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=20

# Criptografia AES-256 para campos sensíveis
ENCRYPTION_KEY=chave-aes-256-bits-aqui-32-chars-obrig

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:3001
