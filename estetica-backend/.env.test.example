# Configuração para Testes de Integração
# ⚠️ NUNCA usar banco de produção nos testes!

# Servidor
PORT=3000
NODE_ENV=test

# Banco de Dados — USAR BANCO DE TESTES SEPARADO
DB_HOST=localhost
DB_PORT=5432
DB_NAME=estetica_ns_test
DB_USER=estetica_user
DB_PASSWORD=estetica_pass

# JWT — Usar secrets diferentes em testes
JWT_SECRET=test-jwt-secret-32-chars-minimum-length
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=test-refresh-secret-32-chars-min
JWT_REFRESH_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Upload
UPLOAD_DIR=./uploads-test
MAX_FILE_SIZE=10485760

# Rate Limiting — Desabilitar em testes
THROTTLE_TTL=60000
THROTTLE_LIMIT=1000
THROTTLE_LOGIN_LIMIT=1000

# Criptografia — Usar chave de teste
ENCRYPTION_KEY=test-encryption-key-32-chars-min

# Frontend URL
FRONTEND_URL=http://localhost:3001
